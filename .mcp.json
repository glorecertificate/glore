{
  "servers": {
    "better-auth": {
      "command": "npx",
      "args": ["@better-auth/mcp", "-y"],
      "type": "stdio"
    },
    "knip": {
      "command": "npx",
      "args": ["@knip/mcp", "-y"],
      "type": "stdio"
    },
    "neondatabase/mcp-server-neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/sse"
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "resend-mcp"],
      "env": {
        "RESEND_API_KEY": "re_xxxxxxxxx"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn", "mcp"],
      "type": "stdio"
    }
  },
  "inputs": []
}
