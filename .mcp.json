{
  "mcpServers": {
    "better-auth": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@better-auth/mcp"],
      "env": {}
    },
    "cloudflare": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/sse"
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": ["shadcn", "mcp"],
      "env": {}
    }
  }
}
