      "type": "stdio",
      "command": "npx",
      "args": ["@better-auth/mcp", "-y"]
    },
    "knip": {
      "type": "stdio",
      "command": "npx",
      "args": ["@knip/mcp", "-y"]
    },
    "neondatabase/mcp-server-neon": {
