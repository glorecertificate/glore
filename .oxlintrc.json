{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "nursery": "allow",
    "pedantic": "error",
    "perf": "error",
    "restriction": "allow",
    "style": "error",
    "suspicious": "error"
  },
  "env": {
    "browser": true,
    "node": true,
    "shared-node-browser": true,
    "es2024": true
  },
  "options": {
    "typeAware": true,
    "typeCheck": false,
    "reportUnusedDisableDirectives": "error",
    "denyWarnings": true
  },
  "plugins": ["import", "jsdoc", "jsx-a11y", "nextjs", "node", "promise", "react", "react-perf"],
  "settings": {
    "next": {
      "rootDir": "."
    },
    "jsdoc": {
      "augmentsExtendsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "ignoreInternal": false,
      "ignorePrivate": false,
      "ignoreReplacesDocs": true,
      "implementsReplacesDocs": false,
      "overrideReplacesDocs": true,
      "tagNamePreference": {}
    }
  },
  "rules": {
    "curly": ["error", "multi-line"],
    "func-style": ["error", "expression"],
    "max-statements": ["error", 100],
    "no-ternary": "off",
    "no-unused-vars": "error",
    "sort-imports": [
      "error",
      {
        "ignoreDeclarationSort": true
      }
    ],
    "eslint/arrow-body-style": ["error", "as-needed"],
    "eslint/capitalized-comments": "off",
    "eslint/eqeqeq": "error",
    "eslint/func-style": "off",
    "eslint/id-length": "off",
    "eslint/init-declarations": "off",
    "eslint/max-depth": ["error", 5],
    "eslint/max-lines": "off",
    "eslint/max-lines-per-function": "off",
    "eslint/new-cap": "off",
    "eslint/no-await-in-loop": "off",
    "eslint/no-cond-assign": "error",
    "eslint/no-console": [
      "warn",
      {
        "allow": ["info", "error", "warn"]
      }
    ],
    "eslint/no-const-assign": "error",
    "eslint/no-continue": "off",
    "eslint/no-debugger": "error",
    "eslint/no-dupe-keys": "error",
    "eslint/no-duplicate-case": "error",
    "eslint/no-duplicate-imports": "off",
    "eslint/no-else-return": "error",
    "eslint/no-empty-pattern": "error",
    "eslint/no-eval": "error",
    "eslint/no-extend-native": "error",
    "eslint/no-extra-boolean-cast": "error",
    "eslint/no-implicit-coercion": "off",
    "eslint/no-implied-eval": "error",
    "eslint/no-inline-comments": "off",
    "eslint/no-iterator": "error",
    "eslint/no-label-var": "error",
    "eslint/no-magic-numbers": "off",
    "eslint/no-nested-ternary": "off",
    "eslint/no-new-func": "error",
    "eslint/no-new-native-nonconstructor": "error",
    "eslint/no-param-reassign": "warn",
    "eslint/no-promise-executor-return": "off",
    "eslint/no-proto": "error",
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "next/headers",
            "importNames": ["cookies"],
            "message": "Use @/actions/cookies instead of cookies from next/headers."
          }
        ],
        "patterns": [
          {
            "group": ["../**"],
            "message": "Parent imports are not allowed. Use @/ path aliases instead."
          }
        ]
      }
    ],
    "eslint/no-return-await": "error",
    "eslint/no-script-url": "error",
    "eslint/no-self-compare": "error",
    "eslint/no-shadow": "error",
    "eslint/no-throw-literal": "error",
    "eslint/no-unreachable": "error",
    "eslint/no-unused-expressions": "error",
    "eslint/no-unused-vars": [
      "error",
      {
        "args": "after-used",
        "argsIgnorePattern": "^_",
        "ignoreRestSiblings": true,
        "vars": "all",
        "varsIgnorePattern": "^_"
      }
    ],
    "eslint/no-useless-catch": "error",
    "eslint/no-useless-concat": "error",
    "eslint/no-useless-constructor": "error",
    "eslint/no-useless-rename": "error",
    "eslint/no-var": "error",
    "eslint/no-void": "off",
    "eslint/no-warning-comments": "off",
    "eslint/no-with": "error",
    "eslint/operator-assignment": "error",
    "eslint/prefer-arrow-callback": "error",
    "eslint/prefer-const": "error",
    "eslint/prefer-destructuring": "off",
    "eslint/prefer-promise-reject-errors": "warn",
    "eslint/prefer-template": "error",
    "eslint/radix": "error",
    "eslint/require-await": "error",
    "eslint/sort-keys": "off",
    "eslint/symbol-description": "warn",
    "eslint/use-isnan": "error",
    "eslint/valid-typeof": "error",
    "import/consistent-type-specifier-style": ["error", "prefer-inline"],
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/max-dependencies": "off",
    "import/no-absolute-path": "error",
    "import/no-anonymous-default-export": "off",
    "import/no-commonjs": "error",
    "import/no-cycle": "error",
    "import/no-duplicates": "error",
    "import/no-named-as-default": "off",
    "import/no-named-export": "off",
    "import/no-namespace": "error",
    "import/no-nodejs-modules": "off",
    "import/no-relative-parent-imports": "error",
    "import/no-self-import": "error",
    "import/no-unassigned-import": "off",
    "import/no-webpack-loader-syntax": "error",
    "import/prefer-default-export": "off",
    "jsdoc/require-param": "off",
    "jsdoc/require-returns": "off",
    "jsx-a11y/alt-text": "error",
    "jsx-a11y/anchor-has-content": "warn",
    "jsx-a11y/anchor-is-valid": "warn",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-role": "error",
    "jsx-a11y/click-events-have-key-events": "allow",
    "jsx-a11y/html-has-lang": "error",
    "jsx-a11y/lang": "error",
    "jsx-a11y/media-has-caption": "allow",
    "jsx-a11y/no-autofocus": "allow",
    "jsx-a11y/no-noninteractive-element-interactions": "allow",
    "jsx-a11y/no-noninteractive-tabindex": "allow",
    "jsx-a11y/no-static-element-interactions": "allow",
    "jsx-a11y/scope": "error",
    "jsx-a11y/tabindex-no-positive": "error",
    "node/no-deprecated-api": "warn",
    "oxc/no-accumulating-spread": "warn",
    "promise/always-return": "error",
    "promise/avoid-new": "off",
    "promise/catch-or-return": "error",
    "promise/no-nesting": "warn",
    "promise/prefer-await-to-callbacks": "off",
    "promise/prefer-await-to-then": "error",
    "react/display-name": "off",
    "react/exhaustive-deps": "error",
    "react/iframe-missing-sandbox": "warn",
    "react/jsx-fragments": ["error", "syntax"],
    "react/jsx-handler-names": "off",
    "react/jsx-key": "error",
    "react/jsx-max-depth": "off",
    "react/jsx-no-constructed-context-values": "error",
    "react/jsx-no-target-blank": "error",
    "react/jsx-no-useless-fragment": "off",
    "react/jsx-props-no-spreading": "off",
    "react/no-array-index-key": "allow",
    "react/no-children-prop": "error",
    "react/no-danger": "allow",
    "react/no-danger-with-children": "error",
    "react/no-deprecated": "warn",
    "react/no-direct-mutation-state": "error",
    "react/no-string-refs": "error",
    "react/no-unescaped-entities": "error",
    "react/react-in-jsx-scope": "off",
    "react/rules-of-hooks": "error",
    "react/self-closing-comp": "error",
    "react/void-dom-elements-no-children": "error",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "typescript/array-type": [
      "error",
      {
        "default": "array"
      }
    ],
    "typescript/ban-ts-comment": [
      "error",
      {
        "ts-check": false,
        "ts-expect-error": "allow-with-description",
        "ts-ignore": true,
        "ts-nocheck": true
      }
    ],
    "typescript/consistent-type-definitions": ["error", "interface"],
    "typescript/consistent-type-imports": [
      "error",
      {
        "fixStyle": "inline-type-imports",
        "prefer": "type-imports"
      }
    ],
    "typescript/no-empty-interface": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-extra-non-null-assertion": "error",
    "typescript/no-inferrable-types": "error",
    "typescript/no-misused-new": "error",
    "typescript/no-non-null-assertion": "allow",
    "typescript/no-require-imports": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/prefer-optional-chain": "warn",
    "unicorn/error-message": "error",
    "unicorn/filename-case": [
      "error",
      {
        "case": "kebabCase",
        "ignore": ["^\\$"]
      }
    ],
    "unicorn/new-for-builtins": "error",
    "unicorn/no-array-for-each": "error",
    "unicorn/no-array-push-result": "warn",
    "unicorn/no-for-loop": "error",
    "unicorn/no-instanceof-array": "error",
    "unicorn/no-negated-condition": "warn",
    "unicorn/no-unnecessary-await": "warn",
    "unicorn/no-useless-promise-resolve-reject": "warn",
    "unicorn/prefer-array-flat": "warn",
    "unicorn/prefer-array-flat-map": "warn",
    "unicorn/prefer-includes": "warn",
    "unicorn/prefer-number-properties": "warn",
    "unicorn/prefer-optional-catch-binding": "warn",
    "unicorn/prefer-prototype-methods": "warn",
    "unicorn/prefer-spread": "warn",
    "unicorn/prefer-string-starts-ends-with": "warn",
    "unicorn/prefer-string-trim-start-end": "warn",
    "unicorn/prefer-structured-clone": "warn",
    "unicorn/prefer-type-error": "warn",
    "unicorn/throw-new-error": "error"
  },
  "overrides": [
    {
      "files": ["src/components/ui/*.tsx", "src/db/*.ts", "src/lib/auth.ts"],
      "rules": {
        "import/no-namespace": "off"
      }
    },
    {
      "files": [
        "src/app/**/layout.tsx",
        "src/app/**/page.tsx",
        "src/app/**/opengraph-image.tsx",
        "src/components/providers/**"
      ],
      "rules": {
        "react-perf/jsx-no-new-array-as-prop": "off",
        "react-perf/jsx-no-new-object-as-prop": "off"
      }
    },
    {
      "files": ["src/components/ui/**/*.tsx", "src/components/blocks/**/*.tsx"],
      "rules": {
        "nextjs/no-img-element": "off"
      }
    }
  ]
}
