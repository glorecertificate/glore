{
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "always",
    "source.fixAll.oxc": "always",
    "source.format.oxc": "always",
    "source.removeUnusedImports": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "i18n-ally.enabledFrameworks": ["next-intl"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.localesPaths": ["./messages"],
  "i18n-ally.namespace": true,
  "js/ts.experimental.useTsgo": true,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.tsdk.path": "./node_modules/typescript/lib",
  "oxc.configPath": "./vite.config.ts",
  "oxc.enable": true,
  "oxc.fixKind": "dangerous_fix_or_suggestion",
  "oxc.fmt.configPath": "./vite.config.ts",
  "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
  "oxc.path.oxlint": "./node_modules/.bin/oxlint",
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(((?:[^()]|\\([^()]*\\))*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cva\\(([^;]*)[\\);]", "[`'\"`]([^'\"`;]*)[`'\"`]"],
    ["(?:\\w+)?[Cc]lassName\\s*=\\s*[{]?[`'\"]([^`'\"]*)[`'\"][}]?"],
    ["fill=['\"]([^'\"]*)"],
    ["stroke=['\"]([^'\"]*)"]
  ],
  "tailwindCSS.experimental.configFile": "./src/app/globals.css",
  "tailwindCSS.files.exclude": ["**/*.md"],
  "tailwindCSS.includeLanguages": {
    "svg": "html"
  },
  "typescript.native-preview.tsdk": "/Users/gabrielecanepa/Developer/@glorecertificate/glore/node_modules/@typescript/native-preview",
  "postman.settings.dotenv-detection-notification-visibility": false
}
