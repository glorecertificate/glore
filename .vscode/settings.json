{
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit",
    "source.format.oxc": "explicit",
    "source.removeUnusedImports": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modifications",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.vercel/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/.agents/skills/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/node_modules": true,
    "**/pnpm-lock.yaml": true,
    "**/tmp": true,
    "**/CHANGELOG.md": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/.vercel": true
  },
  "i18n-ally.enabledFrameworks": ["next-intl"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.localesPaths": ["./messages"],
  "i18n-ally.namespace": true,
  "js/ts.experimental.useTsgo": true,
  "js/ts.preferences.autoImportFileExcludePatterns": ["lucide-react"],
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.tsdk.path": "./node_modules/typescript/lib",
  "oxc.configPath": "./vite.config.ts",
  "oxc.enable": true,
  "oxc.fixKind": "safe_fix_or_suggestion",
  "oxc.fmt.configPath": "./vite.config.ts",
  "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
  "oxc.path.oxlint": "./node_modules/.bin/oxlint",
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(((?:[^()]|\\([^()]*\\))*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cva\\(([^;]*)[\\);]", "[`'\"`]([^'\"`;]*)[`'\"`]"],
    ["(?:\\w+)?[Cc]lassName\\s*=\\s*[{]?[`'\"]([^`'\"]*)[`'\"][}]?"],
    ["fill=['\"]([^'\"]*)"],
    ["stroke=['\"]([^'\"]*)"]
  ],
  "tailwindCSS.experimental.configFile": "./src/app/globals.css",
  "tailwindCSS.files.exclude": ["**/*.md"],
  "tailwindCSS.includeLanguages": {
    "svg": "html"
  },
  "typescript.native-preview.tsdk": "./node_modules/@typescript/native-preview"
}
