{
  "extends": "//",
  "linter": {
    "domains": {
      "react": "all",
      "next": "all"
    },
    "rules": {
      "complexity": {
        "noBannedTypes": "off"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["../**"],
                "message": "Parent imports are not allowed. Use path aliases instead."
              },
              {
                "group": ["next/navigation"],
                "importNamePattern": "usePathname",
                "message": "Import from @/hooks/use-pathname instead."
              },
              {
                "group": ["@udecode/cn"],
                "importNamePattern": "cn",
                "message": "Import from @/lib/utils instead."
              }
            ]
          }
        }
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              ["next", "next/**", "react", "react/**"],
              ":BLANK_LINE:",
              [":PACKAGE:", "!@config/**", "!@glore/**"],
              ":BLANK_LINE:",
              ["@config/**", "@glore/**"],
              ":BLANK_LINE:",
              [":ALIAS:", ":PATH:"]
            ]
          }
        }
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["scripts/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/blocks/**"],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          }
        }
      }
    }
  ]
}
