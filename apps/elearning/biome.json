{
  "extends": "//",
  "linter": {
    "domains": {
      "react": "all",
      "next": "all"
    },
    "rules": {
      "complexity": {
        "noBannedTypes": "off"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["../**"],
                "message": "Parent imports are not allowed. Use path aliases instead."
              },
              {
                "group": ["next/headers"],
                "importNamePattern": "cookies",
                "message": "Import from '@/actions/cookies' instead."
              },
              {
                "group": ["next/navigation"],
                "importNamePattern": "usePathname",
                "message": "Import from '@/hooks/use-pathname' instead."
              },
              {
                "group": ["next/router"],
                "importNamePattern": "useRouter",
                "message": "Import from 'next/navigation' instead."
              },
              {
                "group": ["@udecode/cn"],
                "importNamePattern": "cn",
                "message": "Import from '@/lib/utils' instead."
              },
              {
                "group": ["zod"],
                "importNamePattern": "default",
                "message": "Use the z named import instead."
              }
            ]
          }
        }
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              "react",
              "react/**",
              "next",
              "next/**",
              ":BLANK_LINE:",
              [":PACKAGE:", "!@glore/**", "!@static/**"],
              ":BLANK_LINE:",
              ["@glore/**"],
              ":BLANK_LINE:",
              "@static/**",
              [":ALIAS:", ":PATH:"]
            ]
          }
        }
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["src/actions/cookies.ts", "src/db/types.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    }
  ]
}
