{
  "extends": "@glore/tsconfig/nextjs",
  "include": [".next/types", "*.ts", "src", "supabase/functions"],
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "paths": {
      "next/types/*": ["./.next/types/*"],
      "@/*": ["./src/*"],
      "@config/*": ["./config/*.json"]
    },
    "plugins": [{ "name": "next" }],
    "types": ["deno"]
  }
}
