{
  "extends": "@glore/tsconfig/nextjs",
  "include": [".next/types", "*.ts", "src", "supabase/functions"],
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "paths": {
      "next/types/*": ["./.next/types/*"],
      "@static/*": ["./static/*.json"],
      "@static/translations/*": ["./static/translations/*.json"],
      "@/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }],
    "types": ["deno"]
  }
}
