{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": ["**/*.ts", "**/*.tsx", "**/*.json", "!.next", "!node_modules", "!.vercel"],
    "ignoreUnknown": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "formatter": {
    "enabled": true,
    "attributePosition": "auto",
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 120,
    "useEditorconfig": true
  },
  "linter": {
    "domains": {
      "project": "recommended",
      "react": "all",
      "next": "all"
    },
    "rules": {
      "recommended": true,
      "a11y": {
        "noAutofocus": "off",
        "noStaticElementInteractions": "off",
        "noSvgWithoutTitle": "off",
        "useFocusableInteractive": "off",
        "useKeyWithClickEvents": "off",
        "useMediaCaption": "off",
        "useSemanticElements": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noForEach": "error",
        "noImportantStyles": "off",
        "noUselessStringConcat": "error",
        "useArrowFunction": "error",
        "useSimplifiedLogicExpression": {
          "level": "error",
          "fix": "safe"
        }
      },
      "correctness": {
        "noConstAssign": {
          "level": "error",
          "fix": "safe"
        },
        "noInvalidBuiltinInstantiation": {
          "level": "error",
          "fix": "safe"
        },
        "noNestedComponentDefinitions": "off",
        "noStringCaseMismatch": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedFunctionParameters": {
          "level": "error"
        },
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "useExhaustiveDependencies": {
          "level": "error",
          "fix": "safe"
        },
        "useParseIntRadix": {
          "level": "error",
          "fix": "safe"
        },
        "useUniqueElementIds": "off"
      },
      "nursery": {
        "noJsxLiterals": "error",
        "useConsistentArrowReturn": "error",
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "functions": ["cn", "cva"]
          }
        }
      },
      "performance": {
        "noAccumulatingSpread": "off",
        "noNamespaceImport": "error",
        "useTopLevelRegex": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "style": {
        "noCommonJs": "error",
        "noInferrableTypes": "error",
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["../**"],
                "message": "Parent imports are not allowed. Use path aliases instead."
              },
              {
                "group": ["next/headers"],
                "importNamePattern": "cookies",
                "message": "Import from '@/actions/cookies' instead."
              },
              {
                "group": ["next/router"],
                "importNamePattern": "useRouter",
                "message": "Import from 'next/navigation' instead."
              },
              {
                "group": ["@udecode/cn"],
                "importNamePattern": "cn",
                "message": "Import from '@/lib/utils' instead."
              },
              {
                "group": ["zod"],
                "importNamePattern": "default",
                "message": "Use the z named import instead."
              }
            ]
          }
        },
        "noUnusedTemplateLiteral": "error",
        "noUselessElse": "error",
        "useCollapsedIf": "error",
        "useComponentExportOnlyModules": "off",
        "useConsistentArrayType": {
          "level": "error",
          "fix": "safe",
          "options": {
            "syntax": "shorthand"
          }
        },
        "useConsistentObjectDefinitions": {
          "level": "error",
          "options": {
            "syntax": "shorthand"
          }
        },
        "useConsistentTypeDefinitions": {
          "level": "error",
          "fix": "safe",
          "options": {
            "style": "interface"
          }
        },
        "useConst": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "useForOf": "error",
        "useFragmentSyntax": {
          "level": "error",
          "fix": "safe"
        },
        "useImportType": {
          "level": "on",
          "options": {
            "style": "inlineType"
          }
        },
        "useSelfClosingElements": "error",
        "useShorthandAssign": {
          "level": "error",
          "fix": "safe"
        },
        "useTemplate": {
          "level": "error",
          "fix": "safe"
        }
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["info", "error", "warn"]
          }
        },
        "noDocumentCookie": "off",
        "noDoubleEquals": {
          "level": "error",
          "fix": "safe"
        },
        "noUnknownAtRules": "off",
        "noVar": {
          "level": "error",
          "fix": "safe"
        },
        "useAwait": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              "react",
              "react/**",
              "next",
              "next/**",
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              "~/**",
              ":BLANK_LINE:",
              [":ALIAS:", ":PATH:"]
            ]
          }
        },
        "useSortedAttributes": "on",
        "useSortedProperties": "on"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "quoteStyle": "single",
      "indentStyle": "space",
      "lineWidth": 120,
      "semicolons": "asNeeded",
      "trailingCommas": "es5"
    },
    "parser": {
      "jsxEverywhere": false
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["*.config.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noTemplateCurlyInString": "off"
          }
        }
      }
    },
    {
      "includes": ["src/actions/cookies.ts", "src/db/client.ts", "src/db/types.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/lib/types.ts", "supabase/functions/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/ui/image-cropper.tsx"],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          }
        }
      }
    }
  ]
}
