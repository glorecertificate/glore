{
  "$schema": "./node_modules/knip/schema.json",
  "entry": ["src/i18n.ts"],
  "project": ["src/**/*", "scripts/**/*"],
  "tags": ["-lintignore"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreIssues": {
    "src/actions/**": ["exports"],
    "src/components/ui/**": ["exports", "types"],
    "src/components/blocks/**": ["exports", "types"],
    "src/components/features/**": ["exports"]
  },
  "ignoreDependencies": ["auth", "date-fns", "shadcn"]
}
