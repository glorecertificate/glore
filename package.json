{
  "name": "glore",
  "version": "0.6.14",
  "homepage": "https://glorecertificate.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorecertificate/glore.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "prepare": "vp config && tsx ./scripts/typegen.ts",
    "typegen": "tsx ./scripts/typegen.ts",
    "dev": "portless run --app-port 3030 next dev",
    "dev:clean": "rm -rf .next && portless run --app-port 3030 next dev",
    "build": "next build",
    "start": "portless run next start",
    "typecheck": "tsgo",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix-dangerously",
    "format": "vp fmt",
    "check": "pnpm run --parallel \"/^check:/\"",
    "check:types": "tsgo --noEmit",
    "check:lint": "vp check",
    "check:knip": "knip",
    "deploy:preview": "dotenv -- sh -c 'vercel build && vercel --prebuilt'",
    "deploy:production": "dotenv -- sh -c 'vercel build && vercel --prebuilt --prod'",
    "db": "dotenv -e .env.development.local -e .env -- drizzle-kit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:pull": "tsx ./scripts/db-pull.ts",
    "email": "portless email.glore dotenv -- email dev --dir src/emails --port 3031",
    "release": "dotenv -- release-it --config release.config.ts",
    "analyze": "next experimental-analyze",
    "bump": "corepack use pnpm@latest && pnpm update -Li",
    "skills": "skills experimental_install --yes"
  },
