{
  "name": "glore",
  "version": "0.5.1",
  "homepage": "https://glorecertificate.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorecertificate/glore.git"
  },
  "packageManager": "pnpm@10.32.1",
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "size-limit": [
    {
      "path": ".next/build",
      "limit": "200 kB"
    }
  ],
  "scripts": {
    "prepare": "husky && tsx ./scripts/typegen.ts",
    "typegen": "tsx ./scripts/typegen.ts",
    "dev": "next dev --port 3030",
    "db": "drizzle-kit",
    "email": "dotenv -- email dev --dir src/emails --port 3031",
    "build": "next build",
    "start": "next start --port 3030",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsc --noEmit && oxlint && oxfmt --check && knip",
    "check:parallel": "concurrently -g 'tsc --noEmit' 'oxlint' 'oxfmt --check' 'knip'",
    "check:size": "size-limit",
    "deploy": "vercel build && vercel --prebuilt",
    "deploy:prod": "vercel build && vercel --prebuilt --prod",
    "release": "dotenv release-it --",
    "analyze": "next experimental-analyze",
    "bump": "corepack use pnpm@latest && pnpm update -Li",
    "skills": "skills experimental_install --yes"
  },
