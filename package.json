{
  "name": "glore",
  "version": "0.6.11",
  "homepage": "https://glorecertificate.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorecertificate/glore.git"
  },
  "scripts": {
    "prepare": "vp config && tsx ./scripts/typegen.ts",
    "typegen": "tsx ./scripts/typegen.ts",
    "dev": "portless run next dev",
    "dev:clean": "rm -rf .next/dev/cache && portless run next dev",
    "build": "next build",
    "start": "portless run next start",
    "typecheck": "tsgo",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix-dangerously",
    "format": "vp fmt",
    "check": "tsgo && vp check && knip",
    "check:ci": "concurrently -g 'tsgo' 'vp check' 'knip'",
    "check:fix": "concurrently -g 'tsgo' 'vp check --fix' 'knip --fix'",
    "check:size": "size-limit",
    "deploy:preview": "dotenv -- sh -c 'vercel build && vercel --prebuilt'",
    "deploy:prod": "dotenv -- sh -c 'vercel build && vercel --prebuilt --prod'",
    "db": "dotenv -e .env.development.local -e .env -- drizzle-kit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:pull": "tsx ./scripts/db-pull.ts",
    "email": "portless glore-email dotenv -- email dev --dir src/emails --port 3031",
    "release": "dotenv -- release-it --config release.config.ts",
    "analyze": "next experimental-analyze",
    "bump": "corepack use pnpm@latest && pnpm update -Li"
  },
