    "check:size": "size-limit",
    "deploy:preview": "dotenv -- sh -c 'vercel build && vercel --prebuilt'",
    "deploy:prod": "dotenv -- sh -c 'vercel build && vercel --prebuilt --prod'",
    "db": "drizzle-kit",
    "email": "dotenv -- email dev --dir src/emails --port 3031",
    "release": "dotenv -- release-it",
    "analyze": "next experimental-analyze",
    "bump": "corepack use pnpm@latest && pnpm update -Li",
    "skills": "skills experimental_install --yes"
  },
