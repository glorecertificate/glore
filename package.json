    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsc --noEmit && oxlint && oxfmt --check && knip",
    "check:ci": "concurrently -g 'tsc --noEmit' 'oxlint' 'oxfmt --check' 'knip'",
