{
  "include": [".next/dev/types/**/*.ts", ".next/types/**/*.ts", "scripts", "src", "supabase/functions", "*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "next/types/*": ["./.next/types/*"],
      "@config/*": ["./config/*.json"],
      "@config/translations/*": ["./config/translations/*.json"],
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "removeComments": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "target": "esnext",
    "types": ["deno", "next", "node", "react", "react-dom"]
  }
}
